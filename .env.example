SUPABASE_URL=###
SUPABASE_KEY=###
SUPABASE_SERVICE_ROLE_KEY=###

# --- S-04 cloud pipeline ---------------------------------------------------
# Cost guard for the async Cloud-AI pipeline. Keep false in prod until S-05's
# daily cap lands; the Edge Function `/start` route no-ops when not "true".
CLOUD_PIPELINE_ENABLED=false

# --- S-05 cloud daily cap --------------------------------------------------
# Global Cloud AI jobs allowed per UTC day (across ALL users). create-job
# rejects the request with 429 daily_cap_reached once reached. 0 disables
# cloud entirely (operator kill-switch). Defaults to 50 if unset.
CLOUD_DAILY_CAP=50

# --- Sentry (error tracking + light tracing) -------------------------------
# DSN is public by design (safe to ship to the browser). Same value for both:
# the server entry point reads SENTRY_DSN; the browser reads PUBLIC_SENTRY_DSN.
# For local workerd dev, set SENTRY_DSN in .dev.vars (NOT .env). Leave blank to
# disable Sentry. SENTRY_AUTH_TOKEN (build-time source-map upload) is wired in
# Phase 3 — CI/GitHub secret, never committed.
SENTRY_DSN=###
PUBLIC_SENTRY_DSN=###
# Sentry environment tag (not secret) — keeps local/dev events out of the prod
# stream. Defaults to "development" if unset; set to "production" in CI/prod.
PUBLIC_SENTRY_ENVIRONMENT=development

# Edge Function secrets (set via `supabase secrets set …`, NOT Worker secrets;
# never commit real values). SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY are
# auto-injected into the Edge runtime — do not set them there.
#   REPLICATE_API_TOKEN ............ Replicate API token for predictions.create
#   REPLICATE_WEBHOOK_SIGNING_SECRET  verifies the /callback signature
#   DB_WEBHOOK_SECRET .............. bearer the /start route checks (DB webhook)
REPLICATE_API_TOKEN=###
REPLICATE_WEBHOOK_SIGNING_SECRET=###
DB_WEBHOOK_SECRET=###
