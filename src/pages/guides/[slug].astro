---
import Layout from "@/layouts/Layout.astro";
import type { CollectionEntry } from "astro:content";
import { getCollection, render } from "astro:content";

// Prerendered inside the SSR app (the `prerender = false` hard rule is for API
// routes only). Each guide markdown file becomes one static /guides/<slug> page;
// the slug is the filename (glob loader `entry.id`). These slugs are the link
// targets for the Phase 3 landing teasers and the Phase 5 sitemap entries.
export const prerender = true;

export async function getStaticPaths() {
  const guides = await getCollection("guides");
  return guides.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"guides">;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, readingMinutes, publishedAt, cover, coverAlt, credits } = entry.data;

const published = publishedAt.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Layout
  title={`${title} — LuminaClean AI`}
  description={description}
  ogImage={cover}
  ogType="article"
  canonical={`/guides/${entry.id}/`}
>
  <link rel="preload" slot="head" href="/fonts/fraunces-600.woff2" as="font" type="font/woff2" crossorigin />
  <main class="min-h-screen bg-(--lc-void) px-4 py-10 text-(--lc-ink) sm:py-14">
    <article class="lc-article mx-auto max-w-[46rem]">
      <a
        href="/"
        class="font-lc-mono text-[11px] tracking-[0.14em] text-(--lc-dim) uppercase transition-colors hover:text-(--lc-ink)"
      >
        ← Back to LuminaClean
      </a>

      <p class="font-lc-mono mt-8 text-[11px] tracking-[0.14em] text-(--lc-faint) uppercase">
        Guide · {readingMinutes} min read · {published}
      </p>
      <h1 class="lc-h1 mt-3 text-3xl text-balance sm:text-[2.6rem]">{title}</h1>
      <p class="mt-4 text-[15px] leading-relaxed text-(--lc-dim)">{description}</p>

      <img
        src={cover}
        alt={coverAlt}
        width="920"
        height="518"
        class="mt-8 aspect-[16/9] w-full rounded-(--lc-radius) object-cover"
      />

      <div class="lc-body mt-10">
        <Content />
      </div>

      {
        credits.length > 0 && (
          <footer class="mt-14 border-t border-white/8 pt-6">
            <h2 class="font-lc-mono text-[11px] tracking-[0.14em] text-(--lc-faint) uppercase">Image credits</h2>
            <ul class="mt-3 space-y-1.5 text-[12.5px] text-(--lc-dim)">
              {credits.map((c) => (
                <li>
                  <a
                    href={c.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="underline decoration-white/20 underline-offset-2 transition-colors hover:text-(--lc-ink)"
                  >
                    {c.source}
                  </a>{" "}
                  · {c.license}
                </li>
              ))}
            </ul>
          </footer>
        )
      }

      <div class="mt-12">
        <a
          href="/"
          class="font-lc-display bg-beam shadow-bloom inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-extrabold text-(--lc-void) transition-transform hover:-translate-y-0.5"
        >
          Try it on your photo →
        </a>
      </div>
    </article>
  </main>
</Layout>

<style>
  /* Fraunces 600 — editorial serif for article headings only. The kit's UI
     stays Archivo (display) + system-sans (body); this weight subset (from the
     enhance-ui-refresh design kit) is fetched only on guide pages that render
     serif headings. @font-face is global by nature; the family name is scoped
     to `.lc-article` usage below. */
  @font-face {
    font-family: "Fraunces";
    src: url("/fonts/fraunces-600.woff2") format("woff2");
    font-weight: 600;
    font-style: normal;
    font-display: swap;
  }

  .lc-article {
    font-family: ui-sans-serif, system-ui, "Segoe UI", sans-serif;
  }
  .lc-h1 {
    font-family: "Fraunces", Georgia, serif;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.12;
  }

  /* Rendered markdown body. `<Content />` HTML is emitted at runtime and does
     not carry Astro's scope attribute, so descendants are targeted via
     `:global()` under the scoped `.lc-body` wrapper. */
  .lc-body :global(h2) {
    font-family: "Fraunces", Georgia, serif;
    font-weight: 600;
    font-size: 1.5rem;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin-top: 2.4rem;
    color: var(--lc-ink);
  }
  .lc-body :global(h3) {
    font-family: "Fraunces", Georgia, serif;
    font-weight: 600;
    font-size: 1.2rem;
    line-height: 1.25;
    margin-top: 1.8rem;
    color: var(--lc-ink);
  }
  .lc-body :global(p) {
    color: var(--lc-dim);
    font-size: 15px;
    line-height: 1.7;
    margin-top: 1.1rem;
  }
  .lc-body :global(ul),
  .lc-body :global(ol) {
    color: var(--lc-dim);
    font-size: 15px;
    line-height: 1.7;
    margin-top: 1.1rem;
    padding-left: 1.4rem;
  }
  .lc-body :global(li) {
    margin-top: 0.4rem;
  }
  .lc-body :global(li::marker) {
    color: var(--lc-faint);
  }
  .lc-body :global(strong) {
    color: var(--lc-ink);
    font-weight: 600;
  }
  .lc-body :global(a) {
    color: var(--lc-ink);
    text-decoration: underline;
    text-decoration-color: rgba(255, 255, 255, 0.25);
    text-underline-offset: 2px;
  }
  .lc-body :global(blockquote) {
    margin-top: 1.4rem;
    padding-left: 1rem;
    border-left: 2px solid var(--lc-hairline);
    color: var(--lc-dim);
    font-style: italic;
  }
  .lc-body :global(figure) {
    margin-top: 1.8rem;
  }
  .lc-body :global(img) {
    width: 100%;
    height: auto;
    border-radius: var(--lc-radius);
  }
  .lc-body :global(figcaption) {
    margin-top: 0.6rem;
    font-size: 12.5px;
    line-height: 1.5;
    color: var(--lc-faint);
  }
  /* Before / after side-by-side pair */
  .lc-body :global(.lc-ba) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  .lc-body :global(.lc-ba img) {
    margin: 0;
  }
</style>
