---
import EnhanceWorkspace from "@/components/enhance/EnhanceWorkspace";
import Layout from "@/layouts/Layout.astro";
import { STRINGS } from "@/lib/enhance-strings";
import { createClient } from "@/lib/supabase";
import { SUPABASE_URL, SUPABASE_KEY, CHROMA_POSTPASS_ENABLED, E2E_CHROMA_OVERRIDE } from "astro:env/server";

const { user } = Astro.locals;

// The browser island subscribes to its own job row via Realtime (S-04). It
// needs the publishable URL + anon key and a short-lived user JWT. The access
// token is read only when signed in — anonymous visitors use the Local engine
// and never subscribe. The anon key is publishable (RLS-gated).
let accessToken: string | null = null;
if (user) {
  const supabase = createClient(Astro.request.headers, Astro.cookies);
  if (supabase) {
    const {
      data: { session },
    } = await supabase.auth.getSession();
    accessToken = session?.access_token ?? null;
  }
}

// Chroma post-pass gate. Normally the runtime server secret CHROMA_POSTPASS_ENABLED.
// Test-only override: when the LOCAL/CI-ONLY seam E2E_CHROMA_OVERRIDE is on, `?chroma=1`
// forces it ON for one E2E spec. Two independent guards keep this out of prod: the seam
// is unset there AND the override is honored only on a loopback hostname (CI/Playwright
// serve on localhost). So even a mis-copied prod secret can't create a browser-flippable
// feature — the runtime flag stays the only control in prod.
const isLoopbackHost = ["localhost", "127.0.0.1", "::1", "[::1]"].includes(Astro.url.hostname);
const chromaEnabled =
  E2E_CHROMA_OVERRIDE && isLoopbackHost && Astro.url.searchParams.get("chroma") === "1"
    ? true
    : CHROMA_POSTPASS_ENABLED;
---

<Layout title={STRINGS.page.title}>
  <main class="bg-cosmic min-h-screen px-4 py-10 text-white sm:py-16">
    <div class="mx-auto max-w-2xl text-center">
      <h1 class="text-3xl font-bold sm:text-4xl">{STRINGS.page.heading}</h1>
      <p class="mt-3 text-white/70">
        {STRINGS.page.subtitle}
      </p>
    </div>
    <div class="mt-8">
      <EnhanceWorkspace
        client:load
        isAuthenticated={Boolean(user)}
        supabaseUrl={SUPABASE_URL ?? null}
        supabaseAnonKey={SUPABASE_KEY ?? null}
        accessToken={accessToken}
        chromaEnabled={chromaEnabled}
      />
    </div>
  </main>
</Layout>
