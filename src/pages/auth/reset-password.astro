---
import Layout from "@/layouts/Layout.astro";
import ResetPasswordForm from "@/components/auth/ResetPasswordForm";

// Self-guard: this page is NOT a PROTECTED_ROUTE, so middleware won't gate it.
// It is only usable with an active recovery session established at /auth/confirm.
if (!Astro.locals.user) {
  return Astro.redirect(
    `/auth/forgot-password?error=${encodeURIComponent("That reset link has expired. Please request a new one.")}`,
  );
}

const error = Astro.url.searchParams.get("error");
---

<Layout title="Set a new password">
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div class="w-full max-w-sm rounded-2xl border border-white/10 bg-white/10 p-8 text-white backdrop-blur-xl">
      <h1
        class="mb-6 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-center text-2xl font-bold text-transparent"
      >
        Set a new password
      </h1>
      <p class="mb-6 text-center text-sm text-blue-100/60">Choose a new password for your account.</p>
      <ResetPasswordForm serverError={error} client:load />
    </div>
  </div>
</Layout>
