---
// TEMPORARY — sentry-integration manual verification harness (checks 3.7–3.11).
// Guarded by a secret ?key= so it isn't publicly abusable; returns 404 on a bad
// key (doesn't advertise itself). Revert this file + SentryVerifyClient.tsx after
// verification. See context/changes/sentry-integration/reviews/impl-review.md.
//
//   ?key=<KEY>&case=ssr        → throws server-side  → 3.7 (server source map)
//   ?key=<KEY>&case=signedurl  → throws with a fake signed URL + email → 3.8/3.9 scrub
//   ?key=<KEY>&case=warning    → captureMessage("warning") with a signed URL → 3.11 + scrub
//   ?key=<KEY>&case=client     → renders an island that throws on click → 3.7 (client source map)
export const prerender = false;

import * as Sentry from "@sentry/cloudflare";
import SentryVerifyClient from "@/components/SentryVerifyClient";

const VERIFY_KEY = "sv_7e3c9a1f4b8d62054e9a3c7f1b6d8052";

const kase = Astro.url.searchParams.get("case");
if (Astro.url.searchParams.get("key") !== VERIFY_KEY) {
  return new Response("Not found", { status: 404 });
}

// Sensitive values the scrub MUST redact from the captured event (3.8/3.9). The
// signed URL mimics a Supabase Storage result.* URL with a token query param; the
// email mimics a user address that must never ship.
const FAKE_SIGNED =
  "https://abc.supabase.co/storage/v1/object/sign/photos/uid/jid/result.jpg?token=eyJhbGciOiJIUzI1NiJ9.signedpayloadXYZ&x=1";
const FAKE_EMAIL = "verify-user@example.com";
const ts = Date.now();

if (kase === "ssr") {
  throw new Error(`sentry-verify SSR test ${ts}`);
}
if (kase === "signedurl") {
  throw new Error(`sentry-verify scrub test: failed to fetch ${FAKE_SIGNED} for ${FAKE_EMAIL} (ts ${ts})`);
}
if (kase === "warning") {
  Sentry.captureMessage(`sentry-verify warning: swallow at ${FAKE_SIGNED} for ${FAKE_EMAIL} (ts ${ts})`, "warning");
  await Sentry.flush(2000);
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>sentry-verify</title>
  </head>
  <body>
    <p>sentry-verify — case={kase ?? "(none)"} — ts {ts}</p>
    {kase === "client" && <SentryVerifyClient client:load ts={ts} />}
    {kase === "warning" && <p>warning captured + flushed</p>}
  </body>
</html>
