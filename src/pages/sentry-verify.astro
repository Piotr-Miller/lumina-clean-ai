---
// TEMPORARY — follow-up 3.7 source-map verification harness (sentry-prod-sourcemaps).
// Guarded by a secret ?key= so it isn't publicly abusable; returns 404 on a bad/missing
// key (doesn't advertise itself). REMOVE this file + SentryVerifyClient.tsx in Phase 4
// once both runtimes are confirmed de-minified in Sentry.
// See context/changes/sentry-prod-sourcemaps/plan.md.
//
//   ?key=<KEY>&case=ssr     → throws server-side (workerd)  → verifies SERVER source map
//   ?key=<KEY>&case=client  → island throws on click        → verifies CLIENT source map
export const prerender = false;

import SentryVerifyClient from "@/components/SentryVerifyClient";

const VERIFY_KEY = "sv_938765fb928a892e55f2cb8f0ae353dc";

const kase = Astro.url.searchParams.get("case");
if (Astro.url.searchParams.get("key") !== VERIFY_KEY) {
  return new Response("Not found", { status: 404 });
}

const ts = Date.now();

// Real server-side throw — the workerd Sentry wrapper (sentry.server.config.ts)
// captures it with a genuine src/pages/sentry-verify.astro frame.
if (kase === "ssr") {
  throw new Error(`sentry-verify SSR test ${ts}`);
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>sentry-verify</title>
  </head>
  <body>
    <p>sentry-verify — case={kase ?? "(none)"} — ts {ts}</p>
    {kase === "client" && <SentryVerifyClient client:load ts={ts} />}
  </body>
</html>
