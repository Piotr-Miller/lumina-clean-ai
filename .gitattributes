# Normalize line endings to LF for all text files (cross-platform consistency).
# Without this, Windows checkouts get CRLF via core.autocrlf and Prettier flags
# every line (`Delete ␍`). CI runs on Linux with LF, so this keeps local and CI
# lint in sync. Git stores LF in the repo; the working tree is normalized to LF
# on the next checkout.
* text=auto eol=lf

# Binary types — never normalize, never diff as text.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.avif  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.pdf   binary
